{{! @template theme_edtech/frontpage }}
{{> theme_edtech/head }}

<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}
<div id="page-wrapper" class="d-print-block">
    {{{ output.standard_top_of_body_html }}}

    {{! Navbar with topbar — see templates/navbar.mustache }}
    {{> theme_edtech/navbar }}

    {{! Moodle requires id="maincontent" to be present in every layout.
        It acts as the skip-to-content anchor for accessibility.
        We render it here (hidden visually) so Moodle's check passes. }}
    <span id="maincontent" class="sr-only" aria-hidden="true"></span>
    <div class="d-none" aria-hidden="true">{{{ maincontent }}}</div>

    {{! ── Main content ── }}
    <div id="edt-page" class="edt-frontpage">

        {{! Section 1 — Hero }}
        {{> theme_edtech/sections/hero }}

        {{! Section 2 — Categories }}
        {{> theme_edtech/sections/categories }}

        {{! Section 3 — Featured Courses (dynamic from Moodle DB) }}
        {{> theme_edtech/sections/featured_courses }}

        {{! Section 4 — Why Choose Us / Features }}
        {{> theme_edtech/sections/features }}

        {{! Section 5 — Instructor CTA }}
        {{> theme_edtech/sections/cta }}

        {{! Section 6 — Testimonials }}
        {{> theme_edtech/sections/testimonials }}

    </div>

    {{! Footer — see templates/sections/footer.mustache }}
    {{> theme_edtech/sections/footer }}

    {{{ output.standard_end_of_body_html }}}
</div>
</body>
</html>
