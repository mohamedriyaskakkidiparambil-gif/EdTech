{{! @template theme_edtech/login }}
{{> theme_edtech/head }}

<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}
<div id="page-wrapper">
    {{{ output.standard_top_of_body_html }}}

    <div class="edt-login-wrap">

        {{! ── LEFT PANEL — Brand & Features ── }}
        <div class="edt-login-left">

            {{! Decorative circles }}
            <div class="edt-login-decor-1"></div>
            <div class="edt-login-decor-2"></div>

            {{! Back to home + Logo }}
            <div class="edt-login-left-header">
                <a href="{{homeurl}}" class="edt-login-back">
                    <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                    Back to home
                </a>
            </div>

            <div class="edt-login-brand">
                <div class="edt-login-brand-mark">
                    <i class="fa-solid fa-graduation-cap" aria-hidden="true"></i>
                </div>
                <div>
                    <div class="edt-login-brand-name">{{sitename}}</div>
                    <div class="edt-login-brand-sub">Learning Platform</div>
                </div>
            </div>

            <h2 class="edt-login-left-title">
                Welcome Back! 👋
            </h2>
            <p class="edt-login-left-sub">
                Continue your learning journey. Thousands of courses are waiting for you.
            </p>

            {{! Feature list }}
            <ul class="edt-login-features">
                {{#features}}
                <li>
                    <span class="edt-login-feat-ic">
                        <i class="fa-solid {{icon}}" aria-hidden="true"></i>
                    </span>
                    <span>{{text}}</span>
                </li>
                {{/features}}
            </ul>

            {{! Stats }}
            <div class="edt-login-stats">
                {{#stats}}
                <div class="edt-login-stat">
                    <div class="edt-login-stat-num">{{num}}</div>
                    <div class="edt-login-stat-lbl">{{lbl}}</div>
                </div>
                {{/stats}}
            </div>

        </div>

        {{! ── RIGHT PANEL — Login Form ── }}
        <div class="edt-login-right">

            {{! Language switcher top-right }}
            {{#haslangmenu}}
            <div class="edt-login-lang">
                <div class="edt-lang-pill" id="edtLoginLangPill"
                     role="button" tabindex="0" aria-haspopup="true" aria-expanded="false">
                    <i class="fa-solid fa-globe" aria-hidden="true"></i>
                    <span>{{currentlang}}</span>
                    <i class="fa-solid fa-chevron-down edt-lang-caret" aria-hidden="true"></i>
                    <div class="edt-lang-dropdown" id="edtLoginLangDropdown" role="menu">
                        {{#langlist}}
                        <a class="edt-lang-option {{#active}}is-active{{/active}}"
                           href="{{url}}" role="menuitem" hreflang="{{code}}">
                            <span class="edt-lang-name">{{name}}</span>
                            {{#active}}<i class="fa-solid fa-check edt-lang-check" aria-hidden="true"></i>{{/active}}
                        </a>
                        {{/langlist}}
                    </div>
                </div>
            </div>
            {{/haslangmenu}}

            <div class="edt-login-card">

                {{! Card header }}
                <div class="edt-login-card-header">
                    <div class="edt-login-card-logo">
                        <i class="fa-solid fa-graduation-cap" aria-hidden="true"></i>
                    </div>
                    <h1 class="edt-login-card-title">Sign in to your account</h1>
                    <p class="edt-login-card-sub">Enter your credentials to access your courses</p>
                </div>

                {{! Moodle renders the full login form here (username, password, submit, guest, lang) }}
                <div class="edt-login-form-wrap">
                    {{{ maincontent }}}
                </div>

                {{! Sign up link }}
                {{#signupenabled}}
                <div class="edt-login-signup">
                    <span>Don't have an account?</span>
                    <a href="{{signupurl}}">Create one now</a>
                </div>
                {{/signupenabled}}

            </div>

        </div>

    </div>

    {{{ output.standard_end_of_body_html }}}
</div>
</body>
</html>

{{! Language switcher JS }}
{{#haslangmenu}}
{{#js}}
(function() {
    ['edtLoginLangPill'].forEach(function(id) {
        var pill = document.getElementById(id);
        if (!pill) return;
        var dropdown = pill.querySelector('.edt-lang-dropdown');
        function toggle(open) {
            pill.setAttribute('aria-expanded', open ? 'true' : 'false');
            dropdown.classList.toggle('open', open);
        }
        pill.addEventListener('click', function(e) { e.stopPropagation(); toggle(!dropdown.classList.contains('open')); });
        pill.addEventListener('keydown', function(e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(!dropdown.classList.contains('open')); } if (e.key === 'Escape') toggle(false); });
        document.addEventListener('click', function() { toggle(false); });
        dropdown.addEventListener('click', function(e) { e.stopPropagation(); });
    });
})();
{{/js}}
{{/haslangmenu}}
