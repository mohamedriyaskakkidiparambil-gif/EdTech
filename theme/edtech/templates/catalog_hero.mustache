<section class="edt-catalog-hero">
    <div class="edt-container edt-catalog-hero-inner">
        <div>
            <div class="edt-catalog-breadcrumbs">{{{breadcrumbs}}}</div>
            <span class="edt-catalog-kicker">{{#str}}catalog_kicker, theme_edtech{{/str}}</span>
            <h1>{{title}}</h1>
            <p>{{description}}</p>
        </div>
        <div class="edt-catalog-count" aria-label="{{count}} {{countlabel}}">
            <strong>{{count}}</strong>
            <span>{{countlabel}}</span>
        </div>
    </div>
</section>
