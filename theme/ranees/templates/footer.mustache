{{! Ranees EdTech — footer.mustache
    Rich 4-column dark olive footer matching index.html design.
    Moodle's required standard_footer_html and standard_end_of_body_html are preserved.
}}

<footer id="page-footer" class="d-print-none">
    <div class="ranees-footer-inner">
        <div class="ranees-foot-grid">

            {{! Col 1 — Brand + About + Socials }}
            <div class="ranees-foot-about">
                <a href="{{{ config.homeurl }}}" class="navbar-brand d-inline-flex align-items-center gap-2 mb-3" style="color:#fff; text-decoration:none;">
                    <div class="ranees-brand-mark">
                        <i class="fa-solid fa-graduation-cap"></i>
                    </div>
                    <div class="ranees-brand-text">
                        <div class="ranees-brand-name" style="color:#fff;">Ranees <span style="color:var(--gold-300);">EdTech</span></div>
                        <div class="ranees-brand-sub">Learning Platform</div>
                    </div>
                </a>
                <p>A comprehensive educational platform offering a multilingual learning experience with high quality content.</p>
                <div class="ranees-socials">
                    <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#" aria-label="Twitter"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#" aria-label="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
                    <a href="#" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
                </div>
            </div>

            {{! Col 2 — Quick Links }}
            <div>
                <h5>Quick Links</h5>
                <ul>
                    <li><a href="{{{ config.homeurl }}}">Home</a></li>
                    <li><a href="{{{ config.wwwroot }}}/course/">All Courses</a></li>
                    <li><a href="{{{ config.wwwroot }}}/my/">My Dashboard</a></li>
                    <li><a href="{{{ config.wwwroot }}}/user/index.php">Instructors</a></li>
                    <li><a href="{{{ config.wwwroot }}}/blog/">Blog</a></li>
                </ul>
            </div>

            {{! Col 3 — Support }}
            <div>
                <h5>Support</h5>
                <ul>
                    <li><a href="#">Help Center</a></li>
                    <li><a href="#">FAQ</a></li>
                    <li><a href="{{{ config.wwwroot }}}/admin/tool/policy/">Privacy Policy</a></li>
                    <li><a href="{{{ config.wwwroot }}}/admin/tool/policy/">Terms of Use</a></li>
                    <li><a href="#">Contact Us</a></li>
                </ul>
                {{! Moodle required links — login info, docs link }}
                <div style="margin-top:16px; font-size:12px; opacity:.6;">
                    {{{ output.standard_footer_html }}}
                </div>
            </div>

            {{! Col 4 — Newsletter }}
            <div>
                <h5>Newsletter</h5>
                <p style="font-size:14px; color:#bdc7a9;">Get the latest courses and offers directly in your inbox.</p>
                <form class="ranees-newsletter" onsubmit="event.preventDefault();">
                    <input type="email" placeholder="Your email address" aria-label="Email for newsletter">
                    <button type="submit">Subscribe</button>
                </form>
            </div>

        </div>
    </div>

    {{! Copyright bar }}
    <div class="ranees-copyright">
        <div>&copy; 2026 Ranees EdTech Platform. All rights reserved.</div>
        <div>
            <a href="#">Privacy</a> &nbsp;·&nbsp;
            <a href="#">Terms</a> &nbsp;·&nbsp;
            <a href="#">Cookies</a>
        </div>
    </div>

    {{! Moodle required: end of body scripts, debug output }}
    <div class="footer-content-debugging footer-dark bg-dark text-light">
        <div class="container-fluid">
            {{{ output.debug_footer_html }}}
        </div>
    </div>

    {{{ output.standard_end_of_body_html }}}
</footer>

{{#js}}
require(['theme_boost/footer-popover'], function(FooterPopover) {
    FooterPopover.init();
});
{{/js}}
